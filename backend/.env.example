# ---- App ----
PROJECT_NAME=TaskFlow
DEBUG=True

# ---- Database ----
# For local Postgres:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/taskflow
# For docker-compose, host is the service name "db":
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/taskflow

# ---- Security ----
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Frontend ----
FRONTEND_URL=http://localhost:5173

# ---- Email (optional; leave blank to log emails to console in dev) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@taskflow.app
